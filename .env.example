LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
OPENAI_API_KEY=<To use other providers, press Enter for now and edit .env.local>
DEEPGRAM_API_KEY=<To use other providers, press Enter for now and edit .env.local>
ELEVEN_API_KEY=<To use other providers, press Enter for now and edit .env.local>

# TTS provider selection: "elevenlabs" (default) or "60db"
TTS_PROVIDER=elevenlabs
# Required only when TTS_PROVIDER=60db
SIXTYDB_API_KEY=<your 60dB API key, e.g. sk_live_...>
# Optional: 60dB voice id (defaults to the 60dB default voice)
SIXTYDB_VOICE_ID=
